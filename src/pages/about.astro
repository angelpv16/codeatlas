---
import Layout from '../components/layout/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { t, getLangFromUrl } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

const lang: Lang = getLangFromUrl(Astro.url);

const techStack = [
  { name: 'Astro', desc: 'Static site framework', icon: '🚀' },
  { name: 'TypeScript', desc: 'Type-safe JavaScript', icon: '📘' },
  { name: 'Tailwind CSS', desc: 'Utility-first styling', icon: '🎨' },
  { name: 'React', desc: 'Interactive islands', icon: '⚛️' },
  { name: 'MDX', desc: 'Rich content authoring', icon: '📝' },
  { name: 'Shiki', desc: 'Syntax highlighting', icon: '✨' },
];
---
<Layout title={`${t('about.title', lang)} — CodeAtlas`} lang={lang}>
  <Header lang={lang} />

  <main class="flex-1 py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h1 class="text-4xl font-bold text-atlas-text-bright text-center mb-16" data-i18n="about.title">
        {t('about.title', lang)}
      </h1>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Left: Description -->
        <div class="space-y-8">
          <div>
            <p class="text-lg text-atlas-muted leading-relaxed" data-i18n="about.description">
              {t('about.description', lang)}
            </p>
          </div>

          <div class="atlas-card">
            <h2 class="text-xl font-semibold text-atlas-text-bright mb-3" data-i18n="about.philosophy.title">
              {t('about.philosophy.title', lang)}
            </h2>
            <p class="text-atlas-muted leading-relaxed" data-i18n="about.philosophy.desc">
              {t('about.philosophy.desc', lang)}
            </p>
          </div>

          <div class="atlas-card">
            <h2 class="text-xl font-semibold text-atlas-text-bright mb-3" data-i18n="about.why.title">
              {t('about.why.title', lang)}
            </h2>
            <p class="text-atlas-muted leading-relaxed" data-i18n="about.why.desc">
              {t('about.why.desc', lang)}
            </p>
          </div>
        </div>

        <!-- Right: Tech Stack -->
        <div>
          <h2 class="text-xl font-semibold text-atlas-text-bright mb-6" data-i18n="about.tech.title">
            {t('about.tech.title', lang)}
          </h2>

          <div class="space-y-3">
            {techStack.map((tech) => (
              <div class="atlas-card flex items-center gap-4 !p-4">
                <span class="text-2xl" role="img">{tech.icon}</span>
                <div>
                  <h3 class="font-semibold text-atlas-text-bright">{tech.name}</h3>
                  <p class="text-sm text-atlas-muted">{tech.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 atlas-card text-center">
            <p class="text-atlas-muted text-sm" data-i18n="about.builtWith">{t('about.builtWith', lang)}</p>
            <a
              href="https://github.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 mt-4 text-sm text-atlas-accent hover:text-atlas-accent-hover transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              <span data-i18n="footer.source">{t('footer.source', lang)}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
