---
import Layout from '../../components/layout/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import MiniQuiz from '../../components/MiniQuiz';
import { getCollection } from 'astro:content';
import { t, getLangFromUrl } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

export async function getStaticPaths() {
  const concepts = await getCollection('concepts');
  return concepts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const lang: Lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL;

const concepts = await getCollection('concepts');
const sorted = concepts.sort((a, b) => a.data.order - b.data.order);
const currentIndex = sorted.findIndex((c) => c.slug === entry.slug);
const prevConcept = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextConcept = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const displayTitle = lang === 'es' ? entry.data.titleEs : entry.data.title;
const displayDesc = lang === 'es' ? entry.data.descriptionEs : entry.data.description;
const levelLabel = t(`concepts.${entry.data.level}`, lang);
const readTime = t('concepts.readTime', lang);

const badgeClass = {
  beginner: 'atlas-badge-beginner',
  intermediate: 'atlas-badge-intermediate',
  advanced: 'atlas-badge-advanced',
}[entry.data.level];

// Quiz data per concept
const quizzes: Record<string, { question: string; questionEs: string; options: string[]; optionsEs: string[]; correctIndex: number }> = {
  '01-what-is-programming': {
    question: 'What does the print() function do in Python?',
    questionEs: '¿Qué hace la función print() en Python?',
    options: ['Creates a variable', 'Displays output on screen', 'Reads user input', 'Saves a file'],
    optionsEs: ['Crea una variable', 'Muestra texto en pantalla', 'Lee entrada del usuario', 'Guarda un archivo'],
    correctIndex: 1,
  },
  '02-variables': {
    question: 'What is the difference between = and == in Python?',
    questionEs: '¿Cuál es la diferencia entre = y == en Python?',
    options: ['They are the same thing', '= assigns a value, == compares values', '= compares values, == assigns a value', '== is used for strings only'],
    optionsEs: ['Son lo mismo', '= asigna un valor, == compara valores', '= compara valores, == asigna un valor', '== solo se usa para cadenas'],
    correctIndex: 1,
  },
  '03-data-types': {
    question: 'What happens when you run: "5" + 5 in Python?',
    questionEs: '¿Qué pasa cuando ejecutas: "5" + 5 en Python?',
    options: ['Returns 10', 'Returns "55"', 'Raises a TypeError', 'Returns "5 5"'],
    optionsEs: ['Devuelve 10', 'Devuelve "55"', 'Lanza un TypeError', 'Devuelve "5 5"'],
    correctIndex: 2,
  },
  '04-operators': {
    question: 'What does 10 / 2 return in Python?',
    questionEs: '¿Qué devuelve 10 / 2 en Python?',
    options: ['5', '5.0', '2', 'Error'],
    optionsEs: ['5', '5.0', '2', 'Error'],
    correctIndex: 1,
  },
  '05-arrays-and-lists': {
    question: 'What does my_list[-1] return?',
    questionEs: '¿Qué devuelve my_list[-1]?',
    options: ['The first item', 'An error', 'The last item', 'Nothing'],
    optionsEs: ['El primer elemento', 'Un error', 'El último elemento', 'Nada'],
    correctIndex: 2,
  },
  '06-stacks-and-queues': {
    question: "You're building an undo feature. Which structure fits best?",
    questionEs: '¿Estás construyendo una función de deshacer. ¿Qué estructura es mejor?',
    options: ['Queue', 'Stack', 'List', 'Dictionary'],
    optionsEs: ['Queue', 'Stack', 'Lista', 'Diccionario'],
    correctIndex: 1,
  },
  '07-linked-lists': {
    question: 'What is the time complexity of accessing the 5th element in a linked list?',
    questionEs: '¿Cuál es la complejidad temporal de acceder al 5to elemento en una lista enlazada?',
    options: ['O(1)', 'O(log n)', 'O(n)', 'O(n²)'],
    optionsEs: ['O(1)', 'O(log n)', 'O(n)', 'O(n²)'],
    correctIndex: 2,
  },
  '08-hash-tables': {
    question: 'What is the average time complexity for looking up a value in a hash table?',
    questionEs: '¿Cuál es la complejidad temporal promedio para buscar un valor en una tabla hash?',
    options: ['O(n²)', 'O(n)', 'O(log n)', 'O(1)'],
    optionsEs: ['O(n²)', 'O(n)', 'O(log n)', 'O(1)'],
    correctIndex: 3,
  },
  '09-bubble-sort': {
    question: 'What is the worst-case time complexity of bubble sort?',
    questionEs: '¿Cuál es la complejidad temporal en el peor caso de bubble sort?',
    options: ['O(n)', 'O(n log n)', 'O(n²)', 'O(1)'],
    optionsEs: ['O(n)', 'O(n log n)', 'O(n²)', 'O(1)'],
    correctIndex: 2,
  },
  '10-selection-sort': {
    question: 'What is the time complexity of selection sort in all cases?',
    questionEs: '¿Cuál es la complejidad temporal de selection sort en todos los casos?',
    options: ['O(n)', 'O(n log n)', 'O(n²)', 'O(log n)'],
    optionsEs: ['O(n)', 'O(n log n)', 'O(n²)', 'O(log n)'],
    correctIndex: 2,
  },
  '11-insertion-sort': {
    question: 'What is the best-case time complexity of insertion sort?',
    questionEs: '¿Cuál es la complejidad temporal en el mejor caso de insertion sort?',
    options: ['O(n²)', 'O(n log n)', 'O(n)', 'O(1)'],
    optionsEs: ['O(n²)', 'O(n log n)', 'O(n)', 'O(1)'],
    correctIndex: 2,
  },
  '12-linear-search': {
    question: 'What is the worst-case time complexity of linear search?',
    questionEs: '¿Cuál es la complejidad temporal en el peor caso de búsqueda lineal?',
    options: ['O(1)', 'O(log n)', 'O(n)', 'O(n²)'],
    optionsEs: ['O(1)', 'O(log n)', 'O(n)', 'O(n²)'],
    correctIndex: 2,
  },
  '13-binary-search': {
    question: 'What is the time complexity of binary search?',
    questionEs: '¿Cuál es la complejidad temporal de la búsqueda binaria?',
    options: ['O(n)', 'O(n²)', 'O(log n)', 'O(1)'],
    optionsEs: ['O(n)', 'O(n²)', 'O(log n)', 'O(1)'],
    correctIndex: 2,
  },
  '14-recursion': {
    question: 'What happens if a recursive function has no base case?',
    questionEs: '¿Qué pasa si una función recursiva no tiene caso base?',
    options: ['It returns 0', 'It runs once', 'It causes infinite recursion', 'It skips the function'],
    optionsEs: ['Devuelve 0', 'Se ejecuta una vez', 'Causa recursión infinita', 'Salta la función'],
    correctIndex: 2,
  },
};

const quiz = quizzes[entry.slug];
---
<Layout title={`${displayTitle} — CodeAtlas`} description={displayDesc} lang={lang}>
  <!-- Scroll progress bar -->
  <div class="fixed top-0 left-0 w-full h-0.5 z-50 bg-atlas-border">
    <div id="progress-bar" class="h-full bg-atlas-accent" style="width: 0%"></div>
  </div>

  <Header lang={lang} />

  <main class="flex-1 py-12 sm:py-24">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <!-- Back to map -->
      <a href={`${base}map/`} class="inline-flex items-center gap-2 text-sm text-atlas-muted hover:text-atlas-accent transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        <span data-i18n="learn.backToMap">{t('learn.backToMap', lang)}</span>
      </a>

      <!-- Article header -->
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class={badgeClass}>{levelLabel}</span>
          <span class="text-sm text-atlas-muted font-mono">{entry.data.estimatedMinutes} {readTime}</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-semibold text-atlas-text-bright tracking-tight mb-4">
          {displayTitle}
        </h1>
        <p class="text-base text-atlas-muted leading-relaxed">
          {displayDesc}
        </p>
      </header>

      <!-- MDX Content -->
      <article class="prose prose-base prose-atlas max-w-none leading-8">
        <Content />
      </article>

      <!-- Quiz -->
      {quiz && (
        <section class="mt-16 pt-8 border-t border-atlas-line">
          <MiniQuiz
            client:load
            question={lang === 'es' ? quiz.questionEs : quiz.question}
            options={lang === 'es' ? quiz.optionsEs : quiz.options}
            correctIndex={quiz.correctIndex}
            lang={lang}
            nextSlug={nextConcept?.slug}
          />
        </section>
      )}

      <!-- Navigation -->
      <nav class="mt-16 pt-8 border-t border-atlas-line flex items-center justify-between">
        {prevConcept ? (
          <a href={`${base}learn/${prevConcept.slug}/`} class="atlas-btn-secondary text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            <span data-i18n="learn.prevConcept">{t('learn.prevConcept', lang)}</span>
          </a>
        ) : <div />}

        {nextConcept ? (
          <a href={`${base}learn/${nextConcept.slug}/`} class="atlas-btn-primary text-sm">
            <span data-i18n="learn.nextConcept">{t('learn.nextConcept', lang)}</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : <div />}
      </nav>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

<script is:inline>
  const bar = document.getElementById('progress-bar');
  if (bar) {
    window.addEventListener('scroll', function() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      bar.style.width = pct.toFixed(1) + '%';
    }, { passive: true });
  }
</script>
