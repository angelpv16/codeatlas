---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<footer class="mt-auto border-t border-atlas-border bg-atlas-bg">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 text-atlas-text-bright font-bold text-lg mb-3">
          <svg class="w-5 h-5 text-atlas-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
            <path d="M2 12h20" />
          </svg>
          CodeAtlas
        </div>
        <p class="text-sm text-atlas-muted" data-i18n="footer.tagline">{t('footer.tagline', lang)}</p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-semibold text-atlas-text-bright mb-3" data-i18n="footer.nav">{t('footer.nav', lang)}</h3>
        <ul class="space-y-2">
          <li><a href={base} class="text-sm text-atlas-muted hover:text-atlas-text-bright transition-colors" data-i18n="nav.home">{t('nav.home', lang)}</a></li>
          <li><a href={`${base}map/`} class="text-sm text-atlas-muted hover:text-atlas-text-bright transition-colors" data-i18n="nav.map">{t('nav.map', lang)}</a></li>
          <li><a href={`${base}about/`} class="text-sm text-atlas-muted hover:text-atlas-text-bright transition-colors" data-i18n="nav.about">{t('nav.about', lang)}</a></li>
          <li><a href={`${base}roadmap/`} class="text-sm text-atlas-muted hover:text-atlas-text-bright transition-colors" data-i18n="nav.roadmap">{t('nav.roadmap', lang)}</a></li>
        </ul>
      </div>

      <!-- Project -->
      <div>
        <h3 class="text-sm font-semibold text-atlas-text-bright mb-3" data-i18n="footer.project">{t('footer.project', lang)}</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-sm text-atlas-muted hover:text-atlas-text-bright transition-colors" data-i18n="footer.source">
              {t('footer.source', lang)}
            </a>
          </li>
          <li><a href={`${base}roadmap/`} class="text-sm text-atlas-muted hover:text-atlas-text-bright transition-colors" data-i18n="nav.roadmap">{t('nav.roadmap', lang)}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-atlas-border text-center">
      <p class="text-xs text-atlas-muted" data-i18n="about.builtWith">{t('about.builtWith', lang)}</p>
    </div>
  </div>
</footer>
