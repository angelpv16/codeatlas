---
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  titleEs: string;
  description: string;
  descriptionEs: string;
  level: 'beginner' | 'intermediate' | 'advanced';
  section?: 'fundamentals' | 'dsa' | 'algorithms';
  estimatedMinutes: number;
  slug: string;
  lang?: Lang;
}

const {
  title,
  titleEs,
  description,
  descriptionEs,
  level,
  section = 'fundamentals',
  estimatedMinutes,
  slug,
  lang = 'en',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const displayTitle = lang === 'es' ? titleEs : title;
const displayDesc = lang === 'es' ? descriptionEs : description;
const levelLabel = t(`concepts.${level}`, lang);

const badgeClass = {
  beginner: 'atlas-badge-beginner',
  intermediate: 'atlas-badge-intermediate',
  advanced: 'atlas-badge-advanced',
}[level];

const sectionLabel = section === 'dsa' ? 'DSA' : section === 'algorithms' ? (lang === 'es' ? 'Algoritmos' : 'Algorithms') : (lang === 'es' ? 'Fundamentos' : 'Fundamentals');
---
<a href={`${base}learn/${slug}/`}
   class="group block bg-atlas-surface border border-atlas-border rounded-xl p-5 transition-all duration-200 hover:border-atlas-border-2 hover:bg-atlas-surface-2">
  <!-- Top row -->
  <div class="flex items-center justify-between mb-4">
    <span class={badgeClass}>{levelLabel}</span>
    <span class="text-xs text-atlas-muted font-mono">{estimatedMinutes} min</span>
  </div>

  <!-- Title -->
  <h3 class="text-base font-medium text-atlas-text mb-2 group-hover:text-atlas-accent transition-colors duration-200">
    {displayTitle}
  </h3>

  <!-- Description -->
  <p class="text-sm text-atlas-muted leading-relaxed line-clamp-2 mb-4">
    {displayDesc}
  </p>

  <!-- Bottom row -->
  <div class="flex items-center justify-between">
    <span class="text-xs text-atlas-muted font-mono opacity-60">{sectionLabel}</span>
    <svg class="w-4 h-4 text-atlas-muted group-hover:text-atlas-accent group-hover:translate-x-0.5 transition-all duration-200" viewBox="0 0 16 16" fill="none">
      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </div>
</a>
