---
// Interactive linear search visualization for the search algorithms concept
---
<div class="bg-[#0a0c12] border border-[#1e2330] rounded-xl p-6 my-8 not-prose select-none" id="linear-search-container">
  <!-- Target display -->
  <div class="flex items-center justify-between flex-wrap gap-4 mb-5">
    <div class="flex items-center gap-3">
      <span class="text-xs font-mono text-atlas-muted uppercase tracking-wider">Target</span>
      <span id="linear-search-target-display" class="text-2xl font-mono font-bold text-cyan-400">6</span>
    </div>
    <div class="flex items-center gap-2">
      <label for="linear-search-target-input" class="text-xs font-mono text-atlas-muted">Change target:</label>
      <input
        id="linear-search-target-input"
        type="number"
        min="1"
        max="9"
        value="6"
        class="w-14 px-2 py-1 text-sm font-mono text-center bg-atlas-surface border border-atlas-border rounded-md text-atlas-text focus:border-atlas-accent focus:outline-none transition-colors"
      />
    </div>
  </div>

  <!-- Array boxes -->
  <div id="linear-search-array" class="flex gap-2 flex-wrap justify-center mb-5"></div>

  <!-- Step explanation -->
  <div id="linear-search-explanation" class="bg-atlas-surface border border-atlas-border rounded-lg px-4 py-3 mb-5 min-h-[2.75rem] flex items-center">
    <p class="text-sm font-mono text-atlas-muted-2">Press Play or Step to begin searching.</p>
  </div>

  <!-- Controls bar -->
  <div class="flex items-center gap-3 flex-wrap">
    <button id="linear-search-play" class="px-4 py-1.5 text-xs font-mono font-semibold bg-atlas-accent/10 text-atlas-accent rounded-md hover:bg-atlas-accent/20 transition-colors" title="Play / Pause">
      Play
    </button>
    <button id="linear-search-step" class="px-4 py-1.5 text-xs font-mono bg-atlas-border text-atlas-muted rounded-md hover:text-atlas-text transition-colors" title="Step forward">
      Step
    </button>
    <button id="linear-search-reset" class="px-4 py-1.5 text-xs font-mono bg-atlas-border text-atlas-muted rounded-md hover:text-atlas-text transition-colors" title="Reset">
      Reset
    </button>

    <!-- Speed selector -->
    <div class="flex items-center gap-1 ml-auto">
      <span class="text-xs font-mono text-atlas-muted mr-1">Speed:</span>
      <button data-speed="1200" class="linear-search-speed px-2 py-1 text-xs font-mono rounded transition-colors">Slow</button>
      <button data-speed="600" class="linear-search-speed px-2 py-1 text-xs font-mono rounded transition-colors">Normal</button>
      <button data-speed="250" class="linear-search-speed px-2 py-1 text-xs font-mono rounded transition-colors">Fast</button>
    </div>

    <!-- Step counter -->
    <span id="linear-search-counter" class="text-xs font-mono text-atlas-muted ml-2">Step 0 / 0</span>
  </div>
</div>

<script is:inline>
(function () {
  // --- DOM references ---
  var container = document.getElementById('linear-search-container');
  if (!container) return;

  var arrayEl = document.getElementById('linear-search-array');
  var explanationEl = document.getElementById('linear-search-explanation');
  var playBtn = document.getElementById('linear-search-play');
  var stepBtn = document.getElementById('linear-search-step');
  var resetBtn = document.getElementById('linear-search-reset');
  var counterEl = document.getElementById('linear-search-counter');
  var targetDisplay = document.getElementById('linear-search-target-display');
  var targetInput = document.getElementById('linear-search-target-input');
  var speedBtns = container.querySelectorAll('.linear-search-speed');

  if (!arrayEl || !explanationEl || !playBtn || !stepBtn || !resetBtn || !counterEl || !targetDisplay || !targetInput) return;

  // --- Constants ---
  var BASE_ARRAY = [3, 7, 1, 9, 4, 6, 2, 8, 5];

  // --- State ---
  var target = 6;
  var steps = [];
  var currentStep = -1; // -1 = initial state, 0..n = step indices
  var playing = false;
  var interval = null;
  var speed = 600;

  // prefers-reduced-motion
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // --- Step computation ---
  function computeSteps(arr, t) {
    var result = [];
    var checked = [];
    for (var i = 0; i < arr.length; i++) {
      var isMatch = arr[i] === t;
      checked.push(i);
      var explanation;
      if (isMatch) {
        explanation = 'Checking index ' + i + ' \u2014 value is ' + arr[i] + '. Found! Returning index ' + i + '.';
      } else {
        explanation = 'Checking index ' + i + ' \u2014 value is ' + arr[i] + ', not ' + t + '. Moving on.';
      }
      result.push({
        currentIndex: i,
        isMatch: isMatch,
        checked: checked.slice(),
        explanation: explanation
      });
      if (isMatch) break;
    }
    // If target not found, add a final "not found" step
    if (result.length > 0 && !result[result.length - 1].isMatch) {
      result.push({
        currentIndex: -1,
        isMatch: false,
        checked: checked.slice(),
        explanation: 'Value ' + t + ' not found in the array. Search complete.'
      });
    }
    return result;
  }

  // --- Rendering ---
  function renderArray() {
    arrayEl.innerHTML = '';
    for (var i = 0; i < BASE_ARRAY.length; i++) {
      var box = document.createElement('div');
      box.className = 'linear-search-box flex flex-col items-center gap-1';
      box.setAttribute('data-index', String(i));

      var cell = document.createElement('div');
      cell.className = 'w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center rounded-lg text-sm sm:text-base font-mono font-semibold transition-all duration-200';
      cell.textContent = String(BASE_ARRAY[i]);

      var idx = document.createElement('span');
      idx.className = 'text-xs font-mono text-atlas-muted';
      idx.textContent = '[' + i + ']';

      box.appendChild(cell);
      box.appendChild(idx);
      arrayEl.appendChild(box);
    }
    applyHighlights();
  }

  function applyHighlights() {
    var boxes = arrayEl.querySelectorAll('.linear-search-box');
    var step = currentStep >= 0 && currentStep < steps.length ? steps[currentStep] : null;

    for (var i = 0; i < boxes.length; i++) {
      var cell = boxes[i].querySelector('div');
      if (!cell) continue;

      // Remove all dynamic classes
      cell.className = 'w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center rounded-lg text-sm sm:text-base font-mono font-semibold transition-all duration-200';

      // Remove any previous checkmark
      var existing = boxes[i].querySelector('.linear-search-checkmark');
      if (existing) existing.remove();

      if (!step) {
        // Initial state: all unchecked
        cell.className += ' border border-[#1e2330] bg-[#13161e] text-atlas-text';
        continue;
      }

      var isCurrentIndex = step.currentIndex === i;
      var isChecked = step.checked.indexOf(i) !== -1;
      var isFound = isCurrentIndex && step.isMatch;

      if (isFound) {
        // Found: cyan highlight + checkmark
        cell.className += ' border-2 border-cyan-400 bg-cyan-500/10 text-cyan-400';
        var check = document.createElement('span');
        check.className = 'linear-search-checkmark text-xs text-cyan-400 font-bold';
        check.textContent = '\u2713';
        boxes[i].appendChild(check);
      } else if (isCurrentIndex) {
        // Currently checking: indigo highlight
        cell.className += ' border-2 border-indigo-500 bg-indigo-500/10 text-indigo-400';
      } else if (isChecked) {
        // Already checked and not matching: muted
        cell.className += ' border border-[#1e2330] bg-[#13161e] text-atlas-text opacity-40';
      } else {
        // Unchecked
        cell.className += ' border border-[#1e2330] bg-[#13161e] text-atlas-text';
      }
    }
  }

  function updateExplanation() {
    if (currentStep < 0 || currentStep >= steps.length) {
      explanationEl.innerHTML = '<p class="text-sm font-mono text-atlas-muted-2">Press Play or Step to begin searching.</p>';
    } else {
      explanationEl.innerHTML = '<p class="text-sm font-mono text-atlas-muted-2">' + escapeHtml(steps[currentStep].explanation) + '</p>';
    }
  }

  function updateCounter() {
    var display = currentStep < 0 ? 0 : currentStep + 1;
    counterEl.textContent = 'Step ' + display + ' / ' + steps.length;
  }

  function updateControls() {
    playBtn.textContent = playing ? 'Pause' : 'Play';
    stepBtn.style.opacity = playing ? '0.4' : '1';
    stepBtn.style.pointerEvents = playing ? 'none' : 'auto';

    // Disable play if at end and not playing
    var atEnd = currentStep >= steps.length - 1;
    if (atEnd && !playing) {
      playBtn.style.opacity = '0.4';
      playBtn.style.pointerEvents = 'none';
    } else {
      playBtn.style.opacity = '1';
      playBtn.style.pointerEvents = 'auto';
    }
  }

  function updateSpeedButtons() {
    for (var i = 0; i < speedBtns.length; i++) {
      var btn = speedBtns[i];
      var s = parseInt(btn.getAttribute('data-speed') || '600', 10);
      if (s === speed) {
        btn.className = 'linear-search-speed px-2 py-1 text-xs font-mono rounded transition-colors bg-atlas-accent/20 text-atlas-accent';
      } else {
        btn.className = 'linear-search-speed px-2 py-1 text-xs font-mono rounded transition-colors text-atlas-muted hover:text-atlas-text';
      }
    }
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  // --- Actions ---
  function advanceStep() {
    if (currentStep >= steps.length - 1) {
      stopPlay();
      return;
    }
    currentStep++;
    applyHighlights();
    updateExplanation();
    updateCounter();
    updateControls();
  }

  function startPlay() {
    if (currentStep >= steps.length - 1) return;
    playing = true;
    updateControls();
    interval = setInterval(function () {
      advanceStep();
      if (currentStep >= steps.length - 1) {
        stopPlay();
      }
    }, speed);
  }

  function stopPlay() {
    playing = false;
    if (interval) {
      clearInterval(interval);
      interval = null;
    }
    updateControls();
  }

  function resetState() {
    stopPlay();
    currentStep = -1;
    applyHighlights();
    updateExplanation();
    updateCounter();
    updateControls();
  }

  function init() {
    target = parseInt(targetInput.value, 10) || 6;
    if (target < 1) target = 1;
    if (target > 9) target = 9;
    targetDisplay.textContent = String(target);
    steps = computeSteps(BASE_ARRAY, target);
    resetState();
    renderArray();
    updateCounter();
    updateSpeedButtons();

    // prefers-reduced-motion: hide play, only show step
    if (prefersReducedMotion) {
      playBtn.style.display = 'none';
    }
  }

  // --- Event listeners ---
  playBtn.addEventListener('click', function () {
    if (playing) {
      stopPlay();
    } else {
      startPlay();
    }
  });

  stepBtn.addEventListener('click', function () {
    if (!playing) {
      advanceStep();
    }
  });

  resetBtn.addEventListener('click', function () {
    resetState();
    renderArray();
  });

  targetInput.addEventListener('change', function () {
    var val = parseInt(targetInput.value, 10);
    if (isNaN(val) || val < 1) {
      targetInput.value = '1';
    } else if (val > 9) {
      targetInput.value = '9';
    }
    init();
  });

  for (var i = 0; i < speedBtns.length; i++) {
    (function (btn) {
      btn.addEventListener('click', function () {
        speed = parseInt(btn.getAttribute('data-speed') || '600', 10);
        updateSpeedButtons();
        // Restart interval if currently playing
        if (playing) {
          stopPlay();
          startPlay();
        }
      });
    })(speedBtns[i]);
  }

  // --- Initialize ---
  init();
})();
</script>
